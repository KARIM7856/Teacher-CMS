# ─────────────────────────────────────────────────────────────
.dart_tool/
.packages
.pub-cache/
.pub/
build/
.flutter-plugins
.flutter-plugins-dependencies
.metadata
doc/api/
*.dart.js
*.info.json
*.js_
*.js.deps
*.js.map
coverage/

# Android (within the Flutter app)
**/android/.gradle/
**/android/captures/
**/android/local.properties
**/android/key.properties
**/android/**/GeneratedPluginRegistrant.java
*.keystore
*.jks

# iOS (within the Flutter app)
**/ios/Pods/
**/ios/.symlinks/
**/ios/Flutter/Flutter.framework/
**/ios/Flutter/Flutter.podspec
**/ios/Flutter/flutter_export_environment.sh
**/ios/Runner/GeneratedPluginRegistrant.*
**/ios/**/*.mode1v3
**/ios/**/*.pbxuser
**/Podfile.lock

# Note: pubspec.lock is intentionally NOT ignored — apps commit it.

